# YouTube Data API v3 のAPIキー
YOUTUBE_API_KEY=your_youtube_api_key

# Teams投稿先(Incoming Webhook または Power AutomateのHTTPトリガーURL)
TEAMS_WEBHOOK_URL=https://example.com/webhook

# Teams投稿モード: "incomingWebhook" または "powerAutomate"
TEAMS_POST_MODE=incomingWebhook

# 検索クエリ・チャンネルごとに取得する最大件数 (search.listの1回あたりの件数)
MAX_RESULTS_PER_QUERY=25

# 直近何日以内に公開された動画を対象にするか
TARGET_DAYS=30
