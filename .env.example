# YouTube Data API v3 のAPIキー
YOUTUBE_API_KEY=your_youtube_api_key

# Teams投稿先(Incoming Webhook または Power AutomateのHTTPトリガーURL)
TEAMS_WEBHOOK_URL=https://example.com/webhook

# Teams投稿モード: "incomingWebhook" または "powerAutomate"
TEAMS_POST_MODE=incomingWebhook

# 検索クエリ・チャンネルごとに取得する最大件数 (search.listの1回あたりの件数)
MAX_RESULTS_PER_QUERY=25

# 直近何日以内に公開された動画を対象にするか
TARGET_DAYS=30

# --- SharePoint連携(分析用ダッシュボードへの履歴保存。任意設定) ---
# 有効にする場合は true にする(未設定/false の場合は保存処理をスキップする)
SHAREPOINT_ENABLED=false

# Azure ADアプリ登録の情報(README「SharePoint連携の設定方法」参照)
SHAREPOINT_TENANT_ID=your_tenant_id
SHAREPOINT_CLIENT_ID=your_client_id
SHAREPOINT_CLIENT_SECRET=your_client_secret

# 保存先のSharePointサイト(例: contoso.sharepoint.com / /sites/nikorihito)
SHAREPOINT_SITE_HOSTNAME=contoso.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/your-site-name

# 保存先のリスト名(事前に作成しておく必要がある)
SHAREPOINT_LIST_NAME=MinecraftTrendHistory

# 毎週SharePointに保存する上位件数(全候補を保存するとリストが肥大化するため)
SHAREPOINT_SAVE_TOP_N=30

# Teamsカードの「分析ダッシュボードを開く」ボタンのリンク先(SharePointページのURL)
SHAREPOINT_DASHBOARD_URL=https://contoso.sharepoint.com/sites/your-site-name/SitePages/minecraft-dashboard.aspx
